VITE_SUPABASE_ANON_KEY=
VITE_DEV_ORGANIZATION_ID=

# Supabase Edge Function secrets for partner prospect invitations.
# These are server-side only and must never use VITE_ prefixes.
PARTNER_SMTP_HOST=
PARTNER_SMTP_PORT=
PARTNER_SMTP_USERNAME=
PARTNER_SMTP_PASSWORD=
PARTNER_SMTP_FROM_EMAIL=
PARTNER_SMTP_FROM_NAME=
# Optional. Use true for implicit TLS/SMTPS, usually port 465. Use false for STARTTLS/plain SMTP negotiation, usually port 587.
PARTNER_SMTP_SECURE=
